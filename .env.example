# Supabase — get from your Supabase project dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Resend — get from resend.com > API Keys
RESEND_API_KEY=re_your_api_key_here

# Email settings
RESEND_FROM_EMAIL=Dime Solutions <onboarding@resend.dev>
CONTACT_EMAIL=support@dime-solutions.co.ke

# Set to "production" on Railway
NODE_ENV=development
